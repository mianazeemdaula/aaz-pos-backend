{
  "name": "cold-storage",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "bin": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "build:obfuscate": "npm run build && node scripts/obfuscate.js",
    "build:exe": "node scripts/sync-version.js && npm run build && node scripts/patch-fontkit.js && pkg . --no-bytecode --public-packages \"*\" --public --output build/cold-storage.exe && node scripts/post-build.js",
    "start": "node dist/server.js",
    "prod": "npm run build && npm run start",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prisma:generate": "prisma generate",
    "prisma:seed": "ts-node-dev --respawn --transpile-only src/prisma/seed.ts",
    "prisma:seed:tax-schedules": "ts-node-dev --respawn --transpile-only src/prisma/seed-tax-schedules.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "assets": [
      "dist/generated/**/*",
      "src/generated/**/*",
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/client/**/*",
      "node_modules/@prisma/engines/**/*",
      "node_modules/pdfkit/js/data/**/*",
      "fonts/**/*",
      "logo/**/*",
      ".env.example"
    ],
    "scripts": [
      "dist/**/*.js",
      "!dist/generated/**/*.js"
    ],
    "outputPath": "build"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@types/cors": "^2.8.19",
    "@types/multer": "^2.1.0",
    "@types/pdfkit": "^0.17.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.5.1",
    "@types/qrcode": "^1.5.6",
    "javascript-obfuscator": "^4.2.2",
    "pkg": "^5.8.1",
    "prisma": "^7.3.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
